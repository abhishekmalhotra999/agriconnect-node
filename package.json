{
  "name": "agriconnect-backend",
  "private": true,
  "version": "1.0.0",
  "description": "AgriConnect backend deployment entry",
  "main": "app.js",
  "scripts": {
    "postinstall": "npm --prefix node_agriconnect install",
    "dev": "npm --prefix node_agriconnect run dev:backend",
    "start": "node app.js",
    "dev:backend": "npm --prefix node_agriconnect run dev:backend",
    "start:mysql": "npm --prefix node_agriconnect run start:mysql",
    "deploy:build": "echo 'No frontend build required for backend-only deployment'",
    "deploy:start": "npm run start",
    "db:dump:mysql": "npm --prefix node_agriconnect run db:dump:mysql",
    "db:restore:mysql": "npm --prefix node_agriconnect run db:restore:mysql"
  },
  "engines": {
    "node": ">=18"
  }
}
